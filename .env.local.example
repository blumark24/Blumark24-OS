NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# REQUIRED for /api/admin/create-user — get this from Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Tenant AI assistant (POST /api/tenant/ai-assistant) — server-side only
OPENAI_API_KEY=your-openai-api-key
# Optional: gpt-4o-mini (default), gpt-4.1-mini, gpt-4.1-nano
# OPENAI_MODEL=gpt-4o-mini
